<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:dubbo="http://dubbo.apache.org/schema/dubbo"
       xmlns="http://www.springframework.org/schema/beans" xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
       http://dubbo.apache.org/schema/dubbo http://dubbo.apache.org/schema/dubbo/dubbo.xsd http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd">
    <context:property-placeholder/>

    <dubbo:application name="dubbo-provider"/>

    <dubbo:registry address="N/A"/>

    <dubbo:protocol name="dubbo" id="dubbo" port="20880" serialization="hessian2"/>

    <bean id="calcService" class="org.vulhub.impl.CalcServiceImpl"/>

    <dubbo:service interface="org.vulhub.api.CalcService" ref="calcService" protocol="dubbo"/>
</beans>
